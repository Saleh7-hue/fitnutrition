# ══════════════════════════════════════════════
#  FitNutrition Backend — Environment Variables
#  Copy this to .env and fill in your values
# ══════════════════════════════════════════════

# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.XXXXX.mongodb.net/fitnutrition?retryWrites=true&w=majority

# JWT Secret — any long random string (min 32 chars)
JWT_SECRET=FitNutrition_Super_Secret_2025_Change_This!

# JWT Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production

# Frontend URL(s) — comma-separated for multiple
# Example: https://yourusername.github.io,http://localhost:5500
FRONTEND_URL=https://YOUR_GITHUB_USERNAME.github.io

# ── Cloudinary (for food photo uploads) ────────
# Free at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Admin Seed Credentials ───────────────────────
# Used ONCE when running: node scripts/seedAdmin.js
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@fitnutrition.com
ADMIN_PASSWORD=Admin@FitNutrition2025!
